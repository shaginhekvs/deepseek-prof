--- /dev/null
+++ b/vllm/kernels/helion_ops.py
@@ -0,0 +1,115 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Experimental Helion implementations for vLLM IR ops."""
+
+import torch
+from torch import Tensor
+
+from vllm import ir
+from vllm.platforms import current_platform
+
+try:
+    import helion
+    import helion.language as hl
+
+    HELION_AVAILABLE = True
+except Exception:
+    helion = None
+    hl = None
+    HELION_AVAILABLE = False
+
+
+CUDA_ALIKE = current_platform.is_cuda_alike()
+
+
+def _can_view_as_2d(x: Tensor) -> bool:
+    if x.dim() < 2:
+        return False
+    if x.dim() == 2:
+        return True
+    for dim in range(x.dim() - 1):
+        if x.size(dim + 1) != 1 and x.stride(dim) != x.stride(dim + 1) * x.size(
+            dim + 1
+        ):
+            return False
+    return True
+
+
+def _helion_fused_add_rms_norm_supported(
+    x: Tensor,
+    x_residual: Tensor,
+    weight: Tensor | None,
+    epsilon: float,
+    variance_size: int | None = None,
+) -> bool:
+    if not HELION_AVAILABLE:
+        return False
+    if variance_size is not None or weight is None:
+        return False
+    if not (x.is_cuda and x_residual.is_cuda and weight.is_cuda):
+        return False
+    if x.dtype != torch.float16 or x_residual.dtype != x.dtype or weight.dtype != x.dtype:
+        return False
+    if x.shape != x_residual.shape or weight.dim() != 1 or weight.numel() != x.shape[-1]:
+        return False
+    if not (weight.is_contiguous() and _can_view_as_2d(x) and _can_view_as_2d(x_residual)):
+        return False
+    x_2d = x.view(-1, x.shape[-1])
+    residual_2d = x_residual.view(-1, x_residual.shape[-1])
+    if x_2d.stride(1) != 1 or residual_2d.stride(1) != 1:
+        return False
+    if x_2d.shape[0] < 128:
+        return False
+    return x_2d.shape[-1] in (512, 576, 768, 1024, 1536, 2048, 3072, 4096, 5120)
+
+
+if HELION_AVAILABLE:
+
+    @helion.kernel(
+        static_shapes=True,
+        autotune_effort="quick",
+        autotune_budget_seconds=45,
+        autotune_log="/scratch/deepseek-prof/profiles/helion_vllm_ir/"
+        "fused_add_rms_norm_autotune",
+    )
+    def _helion_fused_add_rms_norm_kernel(
+        x: Tensor,
+        x_residual: Tensor,
+        weight: Tensor,
+        epsilon: float,
+    ) -> tuple[Tensor, Tensor]:
+        rows = x.size(0)
+        out = torch.empty_like(x)
+        residual_out = torch.empty_like(x_residual)
+
+        for tile_m in hl.tile(rows):
+            y = x[tile_m, :] + x_residual[tile_m, :]
+            residual_out[tile_m, :] = y
+            variance = (y * y).mean(dim=-1, keepdim=True)
+            out[tile_m, :] = y * torch.rsqrt(variance + epsilon) * weight[None, :]
+
+        return out, residual_out
+
+
+@ir.ops.fused_add_rms_norm.register_impl(
+    "helion",
+    supports_args=_helion_fused_add_rms_norm_supported,
+    supported=CUDA_ALIKE and HELION_AVAILABLE,
+)
+def fused_add_rms_norm(
+    x: Tensor,
+    x_residual: Tensor,
+    weight: Tensor | None,
+    epsilon: float,
+    variance_size: int | None = None,
+) -> tuple[Tensor, Tensor]:
+    assert variance_size is None
+    assert weight is not None
+    original_shape = x.shape
+    out, residual_out = _helion_fused_add_rms_norm_kernel(
+        x.view(-1, original_shape[-1]),
+        x_residual.view(-1, original_shape[-1]),
+        weight,
+        epsilon,
+    )
+    return out.view(original_shape), residual_out.view(original_shape)
