# Rebuildable local environments and package caches.
/env/*
!/env/scratch_env.sh
/cache/*

# Keep the small compiler lab caches; these are useful teaching artifacts.
!/cache/torchinductor_lab/
!/cache/torchinductor_lab/**
!/cache/triton_lab/
!/cache/triton_lab/**

# Upstream source clones are recorded in SOURCE_REVISIONS.md instead of vendored.
/src/

# Local scratch-only runtime directories.
/tmp/
/models/
/datasets/
/config/
/share/
/logs/serve_repeated/
/profiles/serve_repeated/

# Editor and Python noise.
__pycache__/
*.py[cod]
.DS_Store

# Nsight SQLite exports can exceed GitHub's hard file-size limit. Keep
# .nsys-rep plus .stats.txt; regenerate SQLite locally with nsys export/stats.
/profiles/nsys/serve_*.sqlite
